{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/approach",
      "regex": "^/approach(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/approach(?:/)?$"
    },
    {
      "page": "/Approach",
      "regex": "^/Approach(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/Approach(?:/)?$"
    },
    {
      "page": "/contact",
      "regex": "^/contact(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/contact(?:/)?$"
    },
    {
      "page": "/Contact",
      "regex": "^/Contact(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/Contact(?:/)?$"
    },
    {
      "page": "/Home",
      "regex": "^/Home(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/Home(?:/)?$"
    },
    {
      "page": "/robots.txt",
      "regex": "^/robots\\.txt(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/robots\\.txt(?:/)?$"
    },
    {
      "page": "/sitemap.xml",
      "regex": "^/sitemap\\.xml(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/sitemap\\.xml(?:/)?$"
    },
    {
      "page": "/success-stories",
      "regex": "^/success\\-stories(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/success\\-stories(?:/)?$"
    },
    {
      "page": "/SuccessStories",
      "regex": "^/SuccessStories(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/SuccessStories(?:/)?$"
    },
    {
      "page": "/therapies",
      "regex": "^/therapies(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/therapies(?:/)?$"
    },
    {
      "page": "/Therapies",
      "regex": "^/Therapies(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/Therapies(?:/)?$"
    }
  ],
  "dataRoutes": [],
  "rsc": {
    "header": "rsc",
    "varyHeader": "rsc, next-router-state-tree, next-router-prefetch, next-router-segment-prefetch",
    "prefetchHeader": "next-router-prefetch",
    "didPostponeHeader": "x-nextjs-postponed",
    "contentTypeHeader": "text/x-component",
    "suffix": ".rsc",
    "prefetchSuffix": ".prefetch.rsc",
    "prefetchSegmentHeader": "next-router-segment-prefetch",
    "prefetchSegmentSuffix": ".segment.rsc",
    "prefetchSegmentDirSuffix": ".segments"
  },
  "rewriteHeaders": {
    "pathHeader": "x-nextjs-rewritten-path",
    "queryHeader": "x-nextjs-rewritten-query"
  }
}